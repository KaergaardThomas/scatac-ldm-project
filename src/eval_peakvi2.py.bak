"""
eval_peakvi.py — Evaluation and labeling script using scvi-tools PEAKVI.

Description
-----------
This script trains a PEAKVI model to generate a latent representation of single-cell
omics data (sparse peak counts), computes UMAP embeddings, and performs evaluation
using ARI, NMI, AUC-ROC, AUC-PR, and F1 matching the plotting conventions of evaluate.py.

Usage
-----
    uv run python src/eval_peakvi.py --data data/hematopoiesis_GSE129785_FACS_sorted.h5ad
"""

import argparse
import json
import os
import sys

import matplotlib

matplotlib.use("Agg")  # Non-interactive backend for HPC/headless environments
import matplotlib.pyplot as plt
import numpy as np
import scanpy as sc
import scipy.sparse as sp
import scvi
from matplotlib import colormaps
from sklearn.cluster import KMeans
from sklearn.metrics import (
    adjusted_rand_score,
    average_precision_score,
    f1_score,
    normalized_mutual_info_score,
    roc_auc_score,
)
from umap import UMAP

# Configure scvi-tools to utilize multiple dataloader workers without crashing
# scvi.settings.dl_num_workers = 4

# ---------------------------------------------------------------------------
# Plotting Helpers matching evaluate.py style
# ---------------------------------------------------------------------------


def compute_umap(embeddings: np.ndarray, seed: int = 42) -> np.ndarray:
    """Compute UMAP coordinates matching evaluate.py configuration."""
    reducer = UMAP(n_components=2, random_state=seed, min_dist=0.2)
    return reducer.fit_transform(embeddings)


def plot_umap(
    coords: np.ndarray,
    labels: np.ndarray,
    title: str,
    out_path: str,
    label_name: str = "Cell type",
):
    """Save a UMAP scatter plot using the exact styling of evaluate.py."""
    labels = np.asarray(labels).astype(str)
    unique_labels = np.unique(labels)
    cmap = colormaps["tab20"].resampled(max(len(unique_labels), 1))

    fig, ax = plt.subplots(figsize=(8, 6))
    for i, lab in enumerate(unique_labels):
        mask = labels == lab
        ax.scatter(
            coords[mask, 0],
            coords[mask, 1],
            color=[cmap(i)],
            s=2,
            alpha=0.5,
            label=lab,
            rasterized=True,
        )
    ax.set_title(title, fontsize=13)
    ax.set_xlabel("UMAP 1")
    ax.set_ylabel("UMAP 2")
    ax.legend(
        title=label_name,
        markerscale=4,
        bbox_to_anchor=(1.05, 1),
        loc="upper left",
        fontsize=7,
    )
    plt.tight_layout()
    plt.savefig(out_path, dpi=150, bbox_inches="tight")
    plt.close()
    print(f"  Saved: {out_path}")


# ---------------------------------------------------------------------------
# Pipeline Utilities
# ---------------------------------------------------------------------------


def run_peakvi_pipeline(
    data_path: str,
    out_data_path: str,
    out_dir: str,
    accelerator: str,
    devices: int,
    resolution: float,
    min_dist: float,
    min_cells_fraction: float,
    k_override: int = None,
    seed: int = 42,
):
    """Runs the PEAKVI pipeline with matching evaluation and plotting infrastructure."""
    os.makedirs(out_dir, exist_ok=True)
    out_data_dir = os.path.dirname(os.path.abspath(out_data_path))
    if out_data_dir:
        os.makedirs(out_data_dir, exist_ok=True)

    # ---- 1. Data Loading & Memory Optimization --------------------------------
    print("Loading data...")
    try:
        adata = sc.read_h5ad(data_path)
    except Exception as e:
        print(f"File not found locally. Attempting to download to {data_path}...")
        adata = sc.read(
            data_path,
            backup_url="https://figshare.com/ndownloader/files/52859288",
        )

    adata.obs_names_make_unique()
    print(f"Loaded raw shape: {adata.shape}")

    if not sp.isspmatrix_csr(adata.X):
        print("Converting sparse matrix to CSR format to save memory...")
        adata.X = sp.csr_matrix(adata.X)

    # ---- 2. Feature Selection (Crucial for VRAM) ------------------------------
    min_cells = int(adata.n_obs * min_cells_fraction)
    print(
        f"Filtering peaks present in fewer than {min_cells} cells ({min_cells_fraction * 100}%)..."
    )
    sc.pp.filter_genes(adata, min_cells=min_cells)
    print(f"Data shape after filtering: {adata.shape}")

    # ---- 3. Model Setup & Training --------------------------------------------
    print("\nSetting up AnnData for PEAKVI...")
    scvi.model.PEAKVI.setup_anndata(adata)

    print(
        f"Initializing PEAKVI model and training (accelerator='{accelerator}', devices={devices})..."
    )
    model = scvi.model.PEAKVI(adata)

    strategy = (
        "ddp" if (accelerator in ["cuda", "gpu", "auto"] and devices > 1) else "auto"
    )

    model.train(
        accelerator=accelerator,
        devices=devices,
        strategy=strategy,
        batch_size=2048,
        max_epochs=10,
    )

    # ---- 4. Latent Extraction -------------------------------------------------
    print("\nExtracting latent representation...")
    PEAKVI_LATENT_KEY = "X_peakvi"
    latent = model.get_latent_representation()
    adata.obsm[PEAKVI_LATENT_KEY] = latent
    print(f"Latent shape: {latent.shape}")

    # ---- 5. Leiden Clustering (Kept for compatibility) ------------------------
    print(f"\nComputing k-nearest-neighbor graph (use_rep='{PEAKVI_LATENT_KEY}')...")
    sc.pp.neighbors(adata, use_rep=PEAKVI_LATENT_KEY)
    PEAKVI_CLUSTERS_KEY = "clusters_peakvi"

    try:
        sc.tl.leiden(
            adata,
            key_added=PEAKVI_CLUSTERS_KEY,
            resolution=resolution,
            flavor="igraph",
            n_iterations=2,
            directed=False,
        )
    except Exception as e:
        sc.tl.leiden(adata, key_added=PEAKVI_CLUSTERS_KEY, resolution=resolution)

    # ---- 6. Advanced Metric Evaluation & Plotting -----------------------------
    print("\n=== RQ1: Embedding Quality ===")

    # Resolve target ground-truth tracking layout columns
    label_col = None
    for col in [
        "cell_type",
        "CellType",
        "celltype",
        "BioClassification",
        "label",
        "Group",
        "cluster",
    ]:
        if col in adata.obs.columns:
            label_col = col
            break

    summary = {}

    if label_col is not None:
        true_labels = np.asarray(adata.obs[label_col].values)
        unique_labels = np.unique(true_labels)
        n_types = len(unique_labels)

        k = n_types if k_override is None else k_override
        print(f"  Cell type column : '{label_col}'")
        print(
            f"  Using k={k} for K-means clustering matching cluster tracking configuration."
        )

        # K-Means clustering matching evaluate.py
        km = KMeans(n_clusters=k, random_state=seed, n_init=10)
        pred_labels = km.fit_predict(latent)

        ari = adjusted_rand_score(true_labels, pred_labels)
        nmi = normalized_mutual_info_score(true_labels, pred_labels)
        print(f"  PEAKVI Clustering ->  ARI={ari:.4f}  NMI={nmi:.4f}")

        summary["rq1"] = {
            "k": int(k),
            "n_cell_types": int(n_types),
            "cell_type_column": label_col,
            "peakvi": {"ari": float(ari), "nmi": float(nmi)},
        }

        # UMAP Generation mimicking evaluate.py
        print("  Computing UMAP coordinates for PeakVI latent...")
        umap_coords = compute_umap(latent, seed=seed)

        plot_umap(
            umap_coords,
            true_labels,
            title="PEAKVI Cell Embeddings — Cell type (FACS)",
            out_path=os.path.join(out_dir, "umap_peakvi_celltype.png"),
        )
        plot_umap(
            umap_coords,
            pred_labels,
            title="PEAKVI Cell Embeddings — K-means clusters",
            out_path=os.path.join(out_dir, "umap_peakvi_kmeans.png"),
            label_name="Cluster",
        )
    else:
        print("  WARNING: Cell type columns missing. Skipping RQ1 visual output steps.")

    print("\n=== RQ2: Link Prediction / Reconstruction ===")

    # --- OOM FIX: Subsample before dense operations ---
    # Attempting to run get_normalized_expression() and .toarray() on the full
    # dataset will instantly cause an Out-Of-Memory crash. We evaluate on a random subset.
    MAX_CELLS_EVAL = 2000

    if adata.n_obs > MAX_CELLS_EVAL:
        print(
            f"  Subsampling to {MAX_CELLS_EVAL} random cells for memory-safe metric calculation..."
        )
        rng = np.random.default_rng(seed)
        eval_idx = rng.choice(adata.n_obs, size=MAX_CELLS_EVAL, replace=False)
        adata_eval = adata[eval_idx].copy()
    else:
        adata_eval = adata.copy()

    # Get predictions ONLY for the subset
    print("  Generating PEAKVI accessibility probabilities...")
    predictions = model.get_normalized_expression(adata=adata_eval, batch_size=128)

    # Convert only the subset to a dense array
    true_sparse = adata_eval.X
    true_binary = (
        true_sparse.toarray() if sp.issparse(true_sparse) else np.asarray(true_sparse)
    )
    true_binary = (true_binary > 0).astype(np.int32).ravel()

    pred_probs = (
        predictions.to_numpy().ravel()
        if hasattr(predictions, "to_numpy")
        else predictions.ravel()
    )

    # Further cap array size if the peak dimension is unusually massive
    MAX_ELEMENTS = 15_000_000
    if len(true_binary) > MAX_ELEMENTS:
        print(
            f"  Flattened matrix too large. Subsampling {MAX_ELEMENTS} random pairs..."
        )
        rng = np.random.default_rng(seed)
        idx = rng.choice(len(true_binary), size=MAX_ELEMENTS, replace=False)
        true_binary = true_binary[idx]
        pred_probs = pred_probs[idx]

    print("  Calculating AUC-ROC, AUC-PR, and F1...")
    auc_roc = roc_auc_score(true_binary, pred_probs)
    auc_pr = average_precision_score(true_binary, pred_probs)
    f1 = f1_score(true_binary, (pred_probs > 0.5).astype(int))

    summary["rq2"] = {
        "peakvi": {
            "val_auc_roc": float(auc_roc),
            "val_auc_pr": float(auc_pr),
            "val_f1": float(f1),
        }
    }

    # Print Summary Tables in terminal matching evaluate.py format
    print("\n=== Summary ===")
    print(f"\n{'Model':<12} {'AUC-ROC':>10} {'AUC-PR':>10} {'F1':>10}")
    print("-" * 46)
    print(f"{'PEAKVI':<12} {auc_roc:>10.4f} {auc_pr:>10.4f} {f1:>10.4f}")

    if label_col is not None:
        print(f"\n{'Method':<12} {'ARI':>10} {'NMI':>10}")
        print("-" * 35)
        print(f"{'PEAKVI':<12} {ari:>10.4f} {nmi:>10.4f}")

    # Write standardized machine readable summary file
    with open(os.path.join(out_dir, "peakvi_summary.json"), "w") as f:
        json.dump(summary, f, indent=2)
    print(f"\nFull summary saved to: {out_dir}/peakvi_summary.json")

    # ---- 7. Saving Updated Objects --------------------------------------------
    print(f"Writing updated AnnData object to {out_data_path}...")
    adata.write_h5ad(out_data_path)
    print("Done.")


if __name__ == "__main__":
    p = argparse.ArgumentParser(description="Train PEAKVI and generate cluster labels")
    p.add_argument(
        "--data",
        type=str,
        default="data/lung_atlas_preprocessed.h5ad",
        help="Path to input .h5ad file",
    )
    p.add_argument(
        "--out_data",
        type=str,
        default="data/lung_atlas_preprocessed_with_peakvi.h5ad",
        help="Path to save updated .h5ad file",
    )
    p.add_argument(
        "--out_dir",
        type=str,
        default="results/peakvi_eval",
        help="Directory to save plots and evaluation artifacts",
    )
    p.add_argument(
        "--accelerator",
        type=str,
        default="cuda",
        choices=["auto", "cpu", "cuda", "mps"],
        help="Compute accelerator for scvi",
    )
    p.add_argument(
        "--devices",
        type=int,
        default=2,
        help="Number of GPUs/devices to use for training",
    )
    p.add_argument(
        "--resolution", type=float, default=0.2, help="Resolution for Leiden clustering"
    )
    p.add_argument(
        "--min_dist", type=float, default=0.2, help="Minimum distance for UMAP"
    )
    p.add_argument(
        "--min_cells_fraction",
        type=float,
        default=0.01,
        help="Filter out peaks found in less than this fraction of cells (default: 0.01 = 1%)",
    )
    p.add_argument(
        "--k",
        type=int,
        default=None,
        help="K-means clusters override parameters. Default: number of FACS cell types.",
    )
    p.add_argument("--seed", type=int, default=42, help="Random seed")
    args = p.parse_args()

    run_peakvi_pipeline(
        data_path=args.data,
        out_data_path=args.out_data,
        out_dir=args.out_dir,
        accelerator=args.accelerator,
        devices=args.devices,
        resolution=args.resolution,
        min_dist=args.min_dist,
        min_cells_fraction=args.min_cells_fraction,
        k_override=args.k,
        seed=args.seed,
    )
